{
  "name": "typegen",
  "version": "3.2.0-alpha.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:plugin && npm run build:ui",
    "build:plugin": "esbuild src/plugin/controller.ts --bundle --outfile=dist/controller.js --target=es2017 --format=iife",
    "build:ui": "vite build",
    "check": "npm run typecheck && npm run test:regression && npm run build",
    "test:regression": "esbuild scripts/v2-regression-checks.ts --bundle --platform=node --outfile=dist/v2-regression-checks.cjs --format=cjs && node dist/v2-regression-checks.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "opentype.js": "^1.3.4"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.82.0",
    "@types/opentype.js": "^1.3.8",
    "esbuild": "^0.21.5",
    "typescript": "^5.5.4",
    "vite": "^5.4.19",
    "vite-plugin-singlefile": "^2.0.2"
  }
}
